ADK_MODEL=gemini-2.5-flash

# Local A2A specialist endpoints.
TICKET_HISTORY_A2A_URL=http://localhost:8101
KNOWLEDGE_BASE_A2A_URL=http://localhost:8102
ACCOUNT_CONTEXT_A2A_URL=http://localhost:8103
INCIDENT_STATUS_A2A_URL=http://localhost:8104
ESCALATION_POLICY_A2A_URL=http://localhost:8105
DIAGNOSTICS_A2A_URL=http://localhost:8107

# Google AI Studio or Gemini Enterprise Agent Platform authentication. Set one path.
# GOOGLE_GENAI_USE_VERTEXAI is the current SDK switch for the Agent Platform backend.
GOOGLE_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
HIRENEST_TRACE_TO_CLOUD=false

# Optional Gemini Enterprise Agent Search serving config.
HIRENEST_AGENT_SEARCH_SERVING_CONFIG=

# Optional Discord escalation notifications.
# Leave credentials empty, or set HIRENEST_DISCORD_DRY_RUN=true, to keep local demos in dry-run mode.
# Discord webhook messages only require the webhook URL.
HIRENEST_DISCORD_DRY_RUN=false
HIRENEST_DISCORD_WEBHOOK_URL=

# Optional override for local data.
HIRENEST_DATA_DIR=
